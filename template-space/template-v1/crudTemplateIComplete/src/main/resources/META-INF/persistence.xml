<?xml version="1.0" encoding="UTF-8" ?>
    <persistence version="3.2"
                 xmlns="https://jakarta.ee/xml/ns/persistence"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                    https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd">
        <persistence-unit name="templatePU" transaction-type="JTA">
            <jta-data-source>jdbc/templateDB_E</jta-data-source>
            <class>data.domain.Parent</class>
            <class>data.domain.ParentDetail</class>
        </persistence-unit>
            <!-- En caso de error revisar el apartado de Database Data Source -->
    </persistence>