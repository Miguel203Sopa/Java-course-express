<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="templatePU" transaction-type="JTA">

        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

        <jta-data-source>jdbc/templateDB_E</jta-data-source>

        <class>data.domain.Parent</class>
        <class>data.domain.ParentDetail</class>

        <properties>

            <property name="eclipselink.target-database"
                      value="org.eclipse.persistence.platform.database.Oracle12Platform"/>



        </properties>

    </persistence-unit>
</persistence>


